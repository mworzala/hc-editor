{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": [
        "typescript",
        "unicorn",
        "oxc",
        "react",
        "react-perf",
        "jsx-a11y",
        "import",
        "promise",
        "node"
    ],
    "categories": {
        "correctness": "error",
        "suspicious": "error",
        "perf": "warn",
        "pedantic": "warn",
        "style": "off",
        "restriction": "off",
        "nursery": "off"
    },
    "env": {
        "browser": true,
        "node": true,
        "es2024": true
    },
    "settings": {
        "react": {
            "version": "19.2.0"
        }
    },
    "rules": {
        "no-console": ["error", { "allow": ["warn", "error"] }],
        "no-debugger": "error",
        "eqeqeq": "error",
        "no-throw-literal": "error",
        "require-unicode-regexp": "error",
        "no-await-in-loop": "off",
        "require-await": "error",
        "no-unused-vars": "off",
        "max-lines": "off",
        "max-lines-per-function": "off",
        "max-classes-per-file": "off",
        "no-inline-comments": "off",
        "no-promise-executor-return": "off",
        "@typescript-eslint/no-unused-vars": [
            "error",
            { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
        ],
        "@typescript-eslint/consistent-type-imports": "error",
        "@typescript-eslint/no-explicit-any": "warn",
        "@typescript-eslint/no-non-null-assertion": "off",
        "@typescript-eslint/no-floating-promises": "off",
        "react/jsx-key": "error",
        "react/no-array-index-key": "warn",
        "react/no-children-prop": "error",
        "react/jsx-no-target-blank": "error",
        "react/react-in-jsx-scope": "off",
        "jsx-a11y/label-has-associated-control": "off",
        "jsx-a11y/click-events-have-key-events": "off",
        "jsx-a11y/prefer-tag-over-role": "off",
        "jsx-a11y/no-static-element-interactions": "off",
        "react-hooks/exhaustive-deps": "error",
        "react-hooks/rules-of-hooks": "error",
        "react-perf/jsx-no-new-object-as-prop": "off",
        "react-perf/jsx-no-new-function-as-prop": "off",
        "react-perf/jsx-no-new-array-as-prop": "off",
        "react-perf/jsx-no-jsx-as-prop": "off",
        "import/no-unassigned-import": "off",
        "import/max-dependencies": "off",
        "unicorn/no-array-for-each": "off",
        "unicorn/no-null": "off",
        "unicorn/filename-case": "off",
        "unicorn/no-useless-undefined": "off",
        "unicorn/prefer-query-selector": "off",
        "unicorn/require-post-message-target-origin": "off",
        "unicorn/no-immediate-mutation": "off",
        "no-underscore-dangle": ["error", { "allow": ["__configure"] }]
    },
    "ignorePatterns": [
        "node_modules",
        "dist",
        "build",
        "**/dist/**",
        "**/build/**",
        "desktop/frontend/bindings/**",
        "desktop/build/bin/**",
        "**/.vite/**"
    ],
    "overrides": [
        {
            "files": ["common/src/model/**/*.ts", "common/src/model/**/*.tsx"],
            "rules": {
                "no-restricted-imports": ["error", {
                    "paths": [
                        { "name": "react", "message": "Model services must not import React. Hooks belong in a sibling `react.ts` file. See docs/model-architecture.md." },
                        { "name": "react-dom", "message": "Model services must not import React. See docs/model-architecture.md." },
                        { "name": "@base-ui/react", "message": "UI primitives belong in components, not model services." }
                    ],
                    "patterns": ["react/*", "react-dom/*"]
                }],
                "no-underscore-dangle": "off"
            }
        },
        {
            "files": [
                "common/src/model/**/react.ts",
                "common/src/model/**/react.tsx",
                "common/src/model/**/*.test.ts",
                "common/src/model/**/*.test.tsx"
            ],
            "rules": {
                "no-restricted-imports": "off"
            }
        }
    ]
}

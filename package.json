{
    "name": "script-editor",
    "private": true,
    "workspaces": [
        "api",
        "common",
        "design-system",
        "web",
        "desktop/frontend"
    ],
    "type": "module",
    "scripts": {
        "dev:web": "bun --filter @hollowcube/web dev",
        "dev:desktop": "cd desktop && wails3 dev",
        "build:web": "bun --filter @hollowcube/web build",
        "build:desktop": "cd desktop && wails3 build",
        "deploy:web": "bun --filter @hollowcube/web build && bun --filter @hollowcube/web deploy",
        "typecheck": "bun --filter '*' typecheck",
        "test": "bun --filter '*' test",
        "lint": "oxlint && bun run scripts/lint-signals.ts",
        "lint:fix": "oxlint --fix",
        "lint:signals": "bun run scripts/lint-signals.ts",
        "format": "oxfmt",
        "format:check": "oxfmt --check"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "@types/node": "^22.10.0",
        "@typescript/native-preview": "^7.0.0-dev.20260421.2",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.63.0",
        "typescript": "^5.6.3"
    }
}
